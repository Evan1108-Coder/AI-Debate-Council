# AI Debate Council backend environment
# Copy this file to backend/.env or copy the root .env.example to .env.
# backend/.env overrides values from the root .env when both files exist.
# Do not put model names in .env. Add provider API keys only.
# One provider key unlocks all models listed under that provider.

DATABASE_PATH=backend/data/debate_council.db
FRONTEND_ORIGIN=http://localhost:6001
CORS_ORIGINS=http://localhost:6001
DEBATE_ROUNDS=2
LITELLM_TIMEOUT_SECONDS=120
MOCK_LLM_RESPONSES=false

# OpenAI API key
# Enables: gpt-5.4-pro, gpt-5.4-mini, gpt-4o, gpt-4o-mini
OPENAI_API_KEY=

# Anthropic API key
# Enables: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5, claude-3.5-sonnet
ANTHROPIC_API_KEY=

# Google API key
# Enables: gemini-3.1-pro, gemini-3-flash, gemini-2.5-flash-lite
GOOGLE_API_KEY=

# Groq API key for Llama models
# Enables: llama-4-maverick, llama-4-scout, llama-3.3-70b
GROQ_API_KEY=

# MiniMax API key
# Enables: minimax-m2.7, minimax-m2.5-lightning
MINIMAX_API_KEY=

# Moonshot API key
# Enables: kimi-latest, kimi-k2-thinking, kimi-k2-turbo-preview, kimi-k2.5-vision, moonshot-v1-128k
MOONSHOT_API_KEY=
