# ========================
# AI Debate Council - Environment Variables
# ========================
# Copy this file to backend/.env and fill in your API keys.

# --- OpenAI ---
OPENAI_API_KEY=sk-xxxx

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-xxxx

# --- Google Gemini ---
GEMINI_API_KEY=xxxx

# --- Groq (for Llama models) ---
GROQ_API_KEY=gsk_xxxx

# --- MiniMax ---
MINIMAX_API_KEY=xxxx

# --- Server ---
HOST=0.0.0.0
PORT=8000
